# QNS deployer secrets — copy to .env and fill in. .env is gitignored.

# 34-word ML-DSA-87 mnemonic for the QNS deployer wallet on QRL Zond Testnet V2.
# The deployer owns the Root contract and can register the `.qrl` TLD ownership
# to the FIFS registrar. Handle as a production-grade secret.
TESTNET_SEED=

# RPC endpoint for QRL Zond Testnet V2. The qrlwallet.com proxy filters eth_*
# and routes qrl_* calls to a synced gqrl node. See docs/PORT-PLAN.md §2.
TESTNET_RPC_URL=https://qrlwallet.com/api/qrl-rpc/testnet
